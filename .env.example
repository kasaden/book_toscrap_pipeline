# ============================================================
# .env.example — Template de configuration
# ============================================================
# Copier ce fichier en ".env" et remplir les valeurs.
# Le fichier ".env" est dans .gitignore et ne sera jamais commité.
# Ce fichier ".env.example" est safe à commiter.
# ============================================================

# --- Serveur SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Compte Gmail expéditeur ---
SMTP_USER=ton.adresse@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # Mot de passe d'application Gmail (16 caractères)

# --- Destinataire de l'alerte ---
ALERT_EMAIL=destinataire@example.com
